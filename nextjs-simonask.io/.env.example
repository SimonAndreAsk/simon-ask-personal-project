# Copy to .env.local and fill in values (never commit .env.local)
#
# Find your project ID: sanity.io/manage → your project → Project settings

# Public Sanity identifiers (also set on Vercel)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# "staging" = show drafts locally (same as stage.simonask.io on Vercel Preview)
# NEXT_PUBLIC_SITE_ENV=staging

# Studio URL for Presentation / draft preview
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Server-only: Viewer token from sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=

# Server-only: random string for Sanity webhook → /api/revalidate
SANITY_REVALIDATE_SECRET=
